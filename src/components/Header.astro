---
import { Image } from 'astro:assets'
import logoColorida from '../assets/images/logo-colorida.png'
import { NAV_LINKS, SOCIAL_LINKS } from '../consts'
---

<header
  id="header"
  class="fixed top-0 right-0 left-0 z-50 bg-transparent transition-all duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-20 items-center justify-between">
      <!-- Logo (oculto no topo, aparece no scroll) -->
      <a href="/" class="group relative z-50 flex flex-shrink-0 items-center gap-3">
        <Image
          src={logoColorida}
          alt="Projeto Padres"
          class="h-12 w-auto opacity-0 transition-opacity duration-300"
          id="header-logo"
          loading="eager"
          width={48}
        />
        <div
          id="header-title"
          class="text-grafite origin-left scale-90 leading-tight opacity-0 transition-all duration-300"
        >
          <span class="font-display block text-xs font-light sm:text-sm">
            Projeto Padres para a
          </span>
          <span class="font-display block text-xs font-bold tracking-wider uppercase sm:text-sm">
            Igreja de Palmas
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden items-center space-x-8 md:flex">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="nav-link font-medium text-white transition-colors hover:text-amarelo"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="relative z-50 p-2 text-white transition-colors focus:outline-none md:hidden"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <div class="relative flex h-6 w-6 items-center justify-center">
          <!-- Menu icon -->
          <svg
            id="menu-icon"
            class="absolute h-6 w-6 scale-100 rotate-0 opacity-100 transition-all duration-300"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="4" x2="20" y1="12" y2="12"></line>
            <line x1="4" x2="20" y1="6" y2="6"></line>
            <line x1="4" x2="20" y1="18" y2="18"></line>
          </svg>
          <!-- X icon -->
          <svg
            id="close-icon"
            class="absolute h-6 w-6 scale-50 rotate-0 opacity-0 transition-all duration-300"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="bg-grafite/95 fixed inset-0 z-40 flex translate-x-full flex-col items-center justify-center backdrop-blur-xl transition-transform duration-500 ease-in-out md:hidden"
  >
    <nav class="flex flex-col items-center space-y-8">
      {
        NAV_LINKS.map((link, index) => (
          <a
            href={link.href}
            class="nav-item-mobile font-display hover:text-amarelo translate-y-4 transform text-3xl text-white opacity-0 transition-all duration-300"
            style={`transition-delay: ${index * 100}ms`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Divisor -->
    <div class="my-10 h-1 w-16 rounded-full bg-white/10"></div>

    <!-- Social Links -->
    <div class="flex items-center space-x-8">
      {
        SOCIAL_LINKS.instagram && SOCIAL_LINKS.instagram !== '#' && (
          <a
            href={SOCIAL_LINKS.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-amarelo transform text-white/70 transition-colors hover:scale-110"
          >
            <span class="sr-only">Instagram</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-8 w-8"
            >
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('header')!
  const menuBtn = document.getElementById('mobile-menu-btn')!
  const mobileMenu = document.getElementById('mobile-menu')!
  const headerLogo = document.getElementById('header-logo')!
  const headerTitle = document.getElementById('header-title')!
  const menuIcon = document.getElementById('menu-icon')!
  const closeIcon = document.getElementById('close-icon')!
  const navLinks = document.querySelectorAll('.nav-link')
  const mobileNavItems = document.querySelectorAll('.nav-item-mobile')
  let isMenuOpen = false

  function handleScroll() {
    const scrolled = window.scrollY > 100
    header.classList.toggle('bg-white', scrolled)
    header.classList.toggle('shadow-md', scrolled)
    header.classList.toggle('bg-transparent', !scrolled)
    headerLogo.classList.toggle('opacity-100', scrolled)
    headerLogo.classList.toggle('opacity-0', !scrolled)
    headerTitle.classList.toggle('opacity-100', scrolled)
    headerTitle.classList.toggle('opacity-0', !scrolled)
    headerTitle.classList.toggle('scale-100', scrolled)
    headerTitle.classList.toggle('scale-90', !scrolled)
    navLinks.forEach((link) => {
      link.classList.toggle('text-grafite', scrolled)
      link.classList.toggle('text-white', !scrolled)
    })
    if (!isMenuOpen) {
      menuBtn.classList.toggle('text-grafite', scrolled)
      menuBtn.classList.toggle('text-white', !scrolled)
    }
  }

  function toggleMenu() {
    isMenuOpen = !isMenuOpen
    mobileMenu.classList.toggle('translate-x-full', !isMenuOpen)
    mobileMenu.classList.toggle('translate-x-0', isMenuOpen)
    document.body.style.overflow = isMenuOpen ? 'hidden' : ''
    menuBtn.classList.toggle('text-white', isMenuOpen)
    menuBtn.setAttribute('aria-expanded', String(isMenuOpen))
    menuBtn.setAttribute('aria-label', isMenuOpen ? 'Fechar menu' : 'Abrir menu')

    // Toggle icons
    menuIcon.classList.toggle('scale-50', isMenuOpen)
    menuIcon.classList.toggle('-rotate-90', isMenuOpen)
    menuIcon.classList.toggle('opacity-0', isMenuOpen)
    menuIcon.classList.toggle('scale-100', !isMenuOpen)
    menuIcon.classList.toggle('rotate-0', !isMenuOpen)
    menuIcon.classList.toggle('opacity-100', !isMenuOpen)

    closeIcon.classList.toggle('scale-100', isMenuOpen)
    closeIcon.classList.toggle('rotate-90', isMenuOpen)
    closeIcon.classList.toggle('opacity-100', isMenuOpen)
    closeIcon.classList.toggle('scale-50', !isMenuOpen)
    closeIcon.classList.toggle('rotate-0', !isMenuOpen)
    closeIcon.classList.toggle('opacity-0', !isMenuOpen)

    // Animate mobile nav items
    mobileNavItems.forEach((item, i) => {
      if (isMenuOpen) {
        setTimeout(() => {
          item.classList.remove('translate-y-4', 'opacity-0')
          item.classList.add('translate-y-0', 'opacity-100')
        }, i * 100)
      } else {
        item.classList.add('translate-y-4', 'opacity-0')
        item.classList.remove('translate-y-0', 'opacity-100')
      }
    })
  }

  // Close menu when clicking a nav link
  mobileNavItems.forEach((item) => {
    item.addEventListener('click', () => {
      if (isMenuOpen) toggleMenu()
    })
  })

  // Close menu on desktop resize
  const mediaQuery = window.matchMedia('(min-width: 768px)')
  mediaQuery.addEventListener('change', (e) => {
    if (e.matches && isMenuOpen) toggleMenu()
  })

  window.addEventListener('scroll', handleScroll, { passive: true })
  menuBtn.addEventListener('click', toggleMenu)
  handleScroll()
</script>
