---
import { Image, getImage } from 'astro:assets'

interface GalleryItem {
  image: ImageMetadata
  alt: string
  description: string
  location: string
}

interface Props {
  items: GalleryItem[]
}

const { items } = Astro.props

// Generate optimized full-res images for lightbox
const processedItems = await Promise.all(
  items.map(async (item) => {
    const fullRes = await getImage({ src: item.image, width: 1200, format: 'webp', quality: 80 })
    return {
      fullSrc: fullRes.src,
      alt: item.alt,
      description: item.description,
      location: item.location
    }
  })
)
---

<!-- Gallery Grid -->
<div id="gallery-grid" class="grid grid-cols-2 gap-6 md:grid-cols-3">
  {
    items.map((item, index) => (
      <button
        type="button"
        class="gallery-thumb group relative aspect-[4/3] cursor-pointer overflow-hidden rounded-xl bg-gray-100 shadow-sm transition-all duration-300 hover:shadow-md"
        data-index={index}
        aria-label={`Ver foto: ${item.alt}`}
      >
        <Image
          src={item.image}
          alt={item.alt}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
          loading="lazy"
          widths={[300, 400, 600]}
          sizes="(max-width: 768px) 50vw, 33vw"
        />
        <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/50 to-transparent p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          <p class="truncate text-sm font-medium text-white">{item.alt}</p>
        </div>
      </button>
    ))
  }
</div>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Galeria de fotos"
>
  <!-- Overlay -->
  <div id="lightbox-overlay" class="fixed inset-0 bg-black/90 backdrop-blur-sm"></div>

  <!-- Modal Content -->
  <div
    id="lightbox-content"
    class="animate-in zoom-in-95 fade-in bg-background relative z-50 flex h-[95vh] w-full max-w-6xl flex-col overflow-hidden shadow-2xl duration-200 sm:h-[90vh] sm:rounded-2xl"
    style="margin: auto; position: absolute; inset: 0; max-height: 95vh;"
  >
    <div class="flex h-full flex-col overflow-y-auto sm:overflow-hidden">
      <!-- Image Section -->
      <div
        class="group relative flex min-h-[35vh] flex-1 items-center justify-center overflow-hidden bg-black sm:min-h-0"
      >
        <Image
          id="lightbox-image"
          src={items[0].image}
          alt=""
          class="h-auto max-h-full w-auto max-w-full object-contain p-4"
          loading="lazy"
          decoding="async"
          width={1200}
        />

        <!-- Close Button -->
        <button
          id="lightbox-close"
          class="absolute top-4 right-4 z-50 rounded-full bg-black/50 p-2 text-white transition-colors hover:bg-black/70"
          aria-label="Fechar galeria"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-6 w-6"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>

        <!-- Navigation Arrows -->
        <button
          id="lightbox-prev"
          class="absolute top-1/2 left-4 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white transition-colors hover:bg-black/70 focus:ring-2 focus:ring-white focus:outline-none"
          aria-label="Imagem anterior"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-8 w-8"
          >
            <path d="m15 18-6-6 6-6"></path>
          </svg>
        </button>
        <button
          id="lightbox-next"
          class="absolute top-1/2 right-4 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white transition-colors hover:bg-black/70 focus:ring-2 focus:ring-white focus:outline-none"
          aria-label="Próxima imagem"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-8 w-8"
          >
            <path d="m9 18 6-6-6-6"></path>
          </svg>
        </button>
      </div>

      <!-- Details Section -->
      <div class="relative z-10 shrink-0 bg-white p-4 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex-1">
            <div class="space-y-1 text-left">
              <h2 id="lightbox-title" class="text-grafite text-xl font-medium"></h2>
              <p
                id="lightbox-description"
                class="line-clamp-none text-left text-sm leading-relaxed text-gray-600 sm:line-clamp-2"
              >
              </p>
            </div>
          </div>
          <div
            class="flex shrink-0 items-center gap-3 border-t border-gray-100 pt-2 text-gray-500 sm:border-t-0 sm:border-l sm:pt-0 sm:pl-4"
          >
            <div class="hidden rounded-full bg-gray-50 p-2 sm:block">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-[10px] font-semibold tracking-wide text-gray-400 uppercase">
                Localização
              </p>
              <p id="lightbox-location" class="text-xs font-medium text-gray-700"></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Thumbnails Footer -->
      <div
        id="lightbox-thumbnails"
        class="scrollbar-thin scrollbar-thumb-gray-700 flex h-20 min-h-[5rem] shrink-0 items-center justify-start gap-2 overflow-x-auto border-t border-gray-800 bg-gray-900 p-2 md:justify-center"
      >
        {
          items.map((item, index) => (
            <button
              class="lightbox-thumb relative h-14 w-20 flex-shrink-0 overflow-hidden rounded-md opacity-50 transition-all duration-300 hover:scale-105 hover:opacity-100"
              data-index={index}
            >
              <Image
                src={item.image}
                alt={`Thumbnail ${index + 1}`}
                class="h-full w-full object-cover"
                loading="lazy"
                width={80}
                height={56}
              />
            </button>
          ))
        }
      </div>
    </div>
  </div>
</div>

<!-- Gallery data for JS -->
<script type="application/json" id="gallery-data" set:html={JSON.stringify(processedItems)} />

<script>
  const galleryData: Array<{
    fullSrc: string
    alt: string
    description: string
    location: string
  }> = JSON.parse(document.getElementById('gallery-data')!.textContent!)

  const lightbox = document.getElementById('lightbox')!
  const lightboxContent = document.getElementById('lightbox-content')!
  const lightboxOverlay = document.getElementById('lightbox-overlay')!
  const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement
  const lightboxTitle = document.getElementById('lightbox-title')!
  const lightboxDescription = document.getElementById('lightbox-description')!
  const lightboxLocation = document.getElementById('lightbox-location')!
  const lightboxClose = document.getElementById('lightbox-close')!
  const lightboxPrev = document.getElementById('lightbox-prev')!
  const lightboxNext = document.getElementById('lightbox-next')!
  const thumbs = document.querySelectorAll('.gallery-thumb')
  const lightboxThumbs = document.querySelectorAll('.lightbox-thumb')

  let currentIndex = 0
  let lastFocusedElement: HTMLElement | null = null

  function showImage(index: number) {
    currentIndex = index
    const item = galleryData[index]
    lightboxImage.src = item.fullSrc
    lightboxImage.alt = item.alt
    lightboxTitle.textContent = item.alt
    lightboxDescription.textContent = item.description
    lightboxLocation.textContent = item.location

    // Update thumbnail highlighting
    lightboxThumbs.forEach((thumb, i) => {
      if (i === index) {
        thumb.classList.add('scale-105', 'opacity-100', 'ring-2', 'ring-white')
        thumb.classList.remove('opacity-50')
      } else {
        thumb.classList.remove('scale-105', 'opacity-100', 'ring-2', 'ring-white')
        thumb.classList.add('opacity-50')
      }
    })

    // Preload adjacent images
    const nextIdx = (index + 1) % galleryData.length
    const prevIdx = (index - 1 + galleryData.length) % galleryData.length
    new Image().src = galleryData[nextIdx].fullSrc
    new Image().src = galleryData[prevIdx].fullSrc
  }

  function openLightbox(index: number) {
    lastFocusedElement = document.activeElement as HTMLElement
    showImage(index)
    lightbox.classList.remove('hidden')
    document.body.style.overflow = 'hidden'
    lightboxClose.focus()
  }

  function closeLightbox() {
    lightbox.classList.add('hidden')
    document.body.style.overflow = ''
    lastFocusedElement?.focus()
  }

  function nextImage() {
    showImage((currentIndex + 1) % galleryData.length)
  }

  function prevImage() {
    showImage((currentIndex - 1 + galleryData.length) % galleryData.length)
  }

  // Gallery grid click
  thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const index = parseInt(thumb.getAttribute('data-index')!, 10)
      openLightbox(index)
    })
  })

  // Lightbox thumbnail click
  lightboxThumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const index = parseInt(thumb.getAttribute('data-index')!, 10)
      showImage(index)
    })
  })

  // Controls
  lightboxClose.addEventListener('click', closeLightbox)
  lightboxOverlay.addEventListener('click', closeLightbox)
  lightboxPrev.addEventListener('click', (e) => {
    e.stopPropagation()
    prevImage()
  })
  lightboxNext.addEventListener('click', (e) => {
    e.stopPropagation()
    nextImage()
  })

  // Keyboard navigation + focus trap
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return
    if (e.key === 'Escape') closeLightbox()
    else if (e.key === 'ArrowRight') nextImage()
    else if (e.key === 'ArrowLeft') prevImage()
    else if (e.key === 'Tab') {
      const focusable = lightboxContent.querySelectorAll<HTMLElement>(
        'button, [href], [tabindex]:not([tabindex="-1"])'
      )
      const first = focusable[0]
      const last = focusable[focusable.length - 1]
      if (e.shiftKey) {
        if (document.activeElement === first) {
          e.preventDefault()
          last.focus()
        }
      } else {
        if (document.activeElement === last) {
          e.preventDefault()
          first.focus()
        }
      }
    }
  })

  // Touch swipe support
  let touchStartX = 0
  lightboxImage.addEventListener(
    'touchstart',
    (e) => {
      touchStartX = e.changedTouches[0].screenX
    },
    { passive: true }
  )
  lightboxImage.addEventListener('touchend', (e) => {
    const diff = e.changedTouches[0].screenX - touchStartX
    if (Math.abs(diff) > 50) {
      diff > 0 ? prevImage() : nextImage()
    }
  })
</script>
