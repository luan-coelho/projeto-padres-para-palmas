---
import { Image, getImage } from 'astro:assets'

interface GalleryItem {
  image: ImageMetadata
  alt: string
  description: string
  location: string
}

interface Props {
  items: GalleryItem[]
}

const { items } = Astro.props

const processedItems = await Promise.all(
  items.map(async (item) => {
    const fullRes = await getImage({ src: item.image, width: 1200, format: 'webp', quality: 80 })
    return {
      fullSrc: fullRes.src,
      alt: item.alt,
      description: item.description,
      location: item.location
    }
  })
)
---

<!-- Gallery Grid -->
<div id="gallery-grid" class="grid grid-cols-2 gap-6 md:grid-cols-3">
  {
    items.map((item, index) => (
      <button
        type="button"
        class="gallery-thumb group relative aspect-[4/3] cursor-pointer overflow-hidden rounded-xl bg-gray-100 shadow-sm transition-all duration-300 hover:shadow-md"
        data-index={index}
        aria-label={`Ver foto: ${item.alt}`}
      >
        <Image
          src={item.image}
          alt={item.alt}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
          loading="lazy"
          widths={[300, 400, 600]}
          sizes="(max-width: 768px) 50vw, 33vw"
        />
        <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/50 to-transparent p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          <p class="truncate text-sm font-medium text-white">{item.alt}</p>
        </div>
      </button>
    ))
  }
</div>

<!-- Fullscreen Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden flex-col bg-black"
  role="dialog"
  aria-modal="true"
  aria-label="Galeria de fotos"
>
  <!-- Close button (top right) -->
  <button
    id="lightbox-close"
    class="absolute top-3 right-3 z-20 rounded-full bg-white/10 p-2 text-white/70 transition-colors hover:bg-white/20 hover:text-white sm:top-4 sm:right-4"
    aria-label="Fechar galeria"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-6 w-6"
    >
      <path d="M18 6 6 18"></path>
      <path d="m6 6 12 12"></path>
    </svg>
  </button>

  <!-- Image area -->
  <div class="relative flex min-h-0 flex-1 items-center justify-center">
    <img
      id="lightbox-image"
      src=""
      alt=""
      class="max-h-full max-w-full object-contain px-4 py-2 sm:px-16"
    />

    <!-- Navigation Arrows -->
    <button
      id="lightbox-prev"
      class="absolute top-1/2 left-2 -translate-y-1/2 rounded-full bg-white/10 p-2 text-white transition-colors hover:bg-white/20 focus:ring-2 focus:ring-white focus:outline-none sm:left-4 sm:p-3"
      aria-label="Imagem anterior"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-6 w-6 sm:h-8 sm:w-8"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
    </button>
    <button
      id="lightbox-next"
      class="absolute top-1/2 right-2 -translate-y-1/2 rounded-full bg-white/10 p-2 text-white transition-colors hover:bg-white/20 focus:ring-2 focus:ring-white focus:outline-none sm:right-4 sm:p-3"
      aria-label="Próxima imagem"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-6 w-6 sm:h-8 sm:w-8"
      >
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </button>
  </div>

  <!-- Info bar (bottom, above thumbnails) -->
  <div class="flex shrink-0 items-center justify-center gap-2 border-t border-white/10 bg-black/80 px-4 py-3 sm:gap-3 sm:px-6">
    <h2 id="lightbox-title" class="text-sm font-medium text-white sm:text-base"></h2>
    <span class="text-white/30">|</span>
    <p id="lightbox-description" class="text-sm text-white/70"></p>
    <span class="text-white/30">|</span>
    <div class="inline-flex items-center gap-1.5 text-white/50">
      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      <span id="lightbox-location" class="text-xs font-medium"></span>
    </div>
  </div>

  <!-- Thumbnails bar -->
  <div
    id="lightbox-thumbnails"
    class="flex h-20 shrink-0 items-center justify-start gap-2 overflow-x-auto border-t border-white/10 bg-black/80 px-4 py-2 md:justify-center"
  >
    {
      items.map((item, index) => (
        <button
          class="lightbox-thumb relative h-14 w-20 flex-shrink-0 overflow-hidden rounded-md opacity-40 transition-all duration-300 hover:opacity-80"
          data-index={index}
        >
          <Image
            src={item.image}
            alt={`Thumbnail ${index + 1}`}
            class="h-full w-full object-cover"
            loading="lazy"
            width={80}
            height={56}
          />
        </button>
      ))
    }
  </div>
</div>

<!-- Gallery data for JS -->
<script type="application/json" id="gallery-data" set:html={JSON.stringify(processedItems)} />

<script>
  const galleryData: Array<{
    fullSrc: string
    alt: string
    description: string
    location: string
  }> = JSON.parse(document.getElementById('gallery-data')!.textContent!)

  const lightbox = document.getElementById('lightbox')!
  const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement
  const lightboxTitle = document.getElementById('lightbox-title')!
  const lightboxDescription = document.getElementById('lightbox-description')!
  const lightboxLocation = document.getElementById('lightbox-location')!
  const lightboxClose = document.getElementById('lightbox-close')!
  const lightboxPrev = document.getElementById('lightbox-prev')!
  const lightboxNext = document.getElementById('lightbox-next')!
  const thumbs = document.querySelectorAll('.gallery-thumb')
  const lightboxThumbs = document.querySelectorAll('.lightbox-thumb')

  let currentIndex = 0
  let lastFocusedElement: HTMLElement | null = null

  function showImage(index: number) {
    currentIndex = index
    const item = galleryData[index]
    lightboxImage.src = item.fullSrc
    lightboxImage.alt = item.alt
    lightboxTitle.textContent = item.alt
    lightboxDescription.textContent = item.description
    lightboxLocation.textContent = item.location

    lightboxThumbs.forEach((thumb, i) => {
      if (i === index) {
        thumb.classList.add('opacity-100', 'ring-2', 'ring-white')
        thumb.classList.remove('opacity-40')
      } else {
        thumb.classList.remove('opacity-100', 'ring-2', 'ring-white')
        thumb.classList.add('opacity-40')
      }
    })

    // Preload adjacent
    const nextIdx = (index + 1) % galleryData.length
    const prevIdx = (index - 1 + galleryData.length) % galleryData.length
    new Image().src = galleryData[nextIdx].fullSrc
    new Image().src = galleryData[prevIdx].fullSrc
  }

  function openLightbox(index: number) {
    lastFocusedElement = document.activeElement as HTMLElement
    showImage(index)
    lightbox.classList.remove('hidden')
    lightbox.classList.add('flex')
    document.body.style.overflow = 'hidden'
    lightboxClose.focus()
  }

  function closeLightbox() {
    lightbox.classList.add('hidden')
    lightbox.classList.remove('flex')
    document.body.style.overflow = ''
    lastFocusedElement?.focus()
  }

  function nextImage() {
    showImage((currentIndex + 1) % galleryData.length)
  }

  function prevImage() {
    showImage((currentIndex - 1 + galleryData.length) % galleryData.length)
  }

  // Gallery grid click
  thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const index = parseInt(thumb.getAttribute('data-index')!, 10)
      openLightbox(index)
    })
  })

  // Lightbox thumbnail click
  lightboxThumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const index = parseInt(thumb.getAttribute('data-index')!, 10)
      showImage(index)
    })
  })

  // Controls
  lightboxClose.addEventListener('click', closeLightbox)
  lightboxPrev.addEventListener('click', (e) => {
    e.stopPropagation()
    prevImage()
  })
  lightboxNext.addEventListener('click', (e) => {
    e.stopPropagation()
    nextImage()
  })

  // Keyboard navigation + focus trap
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return
    if (e.key === 'Escape') closeLightbox()
    else if (e.key === 'ArrowRight') nextImage()
    else if (e.key === 'ArrowLeft') prevImage()
    else if (e.key === 'Tab') {
      const focusable = lightbox.querySelectorAll<HTMLElement>(
        'button, [href], [tabindex]:not([tabindex="-1"])'
      )
      const first = focusable[0]
      const last = focusable[focusable.length - 1]
      if (e.shiftKey) {
        if (document.activeElement === first) {
          e.preventDefault()
          last.focus()
        }
      } else {
        if (document.activeElement === last) {
          e.preventDefault()
          first.focus()
        }
      }
    }
  })

  // Touch swipe support
  let touchStartX = 0
  lightboxImage.addEventListener(
    'touchstart',
    (e) => {
      touchStartX = e.changedTouches[0].screenX
    },
    { passive: true }
  )
  lightboxImage.addEventListener('touchend', (e) => {
    const diff = e.changedTouches[0].screenX - touchStartX
    if (Math.abs(diff) > 50) {
      diff > 0 ? prevImage() : nextImage()
    }
  })
</script>
