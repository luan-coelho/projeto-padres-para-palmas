---
import { Image } from 'astro:assets'
import Gallery from './Gallery.astro'

import logoColorida from '../assets/images/logo-colorida-st.png'
import foto1 from '../assets/images/galeria/foto1.jpeg'
import foto2 from '../assets/images/galeria/foto2.jpeg'
import foto3 from '../assets/images/galeria/foto3.jpeg'
import foto4 from '../assets/images/galeria/foto4.jpeg'
import foto5 from '../assets/images/galeria/foto5.jpeg'
import foto6 from '../assets/images/galeria/foto6.jpeg'

interface Props {
  sectionLabel?: string
  title?: string
  titleHighlight?: string
  paragraphs?: string[]
  buttonText?: string
  buttonLink?: string
}

const {
  sectionLabel = 'Sobre o Projeto',
  title = 'Um movimento impulsionado pelo',
  titleHighlight = 'desejo de cultivar vocações',
  paragraphs = [
    'Mais que uma ação pastoral ou um programa, o Projeto Padres para a Igreja de Palmas se configura como um movimento em desenvolvimento, impulsionado pelo desejo de cultivar novas vocações para o sacerdócio.',
    'Nascido do coração da Arquidiocese de Palmas, este projeto busca despertar nos jovens o chamado ao ministério presbiteral, fortalecendo a cultura vocacional em nossa Igreja local.'
  ],
  buttonText = 'Saiba mais',
  buttonLink = '#pilares'
} = Astro.props

const galleryItems = [
  {
    image: foto1,
    alt: 'Quilombo Rio Preto',
    description: 'Comunidade Imaculada Conceição',
    location: 'Lagoa do Tocantins - TO'
  },
  {
    image: foto2,
    alt: 'Quilombo Rio Preto',
    description: 'Comunidade Imaculada Conceição',
    location: 'Lagoa do Tocantins - TO'
  },
  {
    image: foto3,
    alt: 'Missão',
    description: 'Território da Paróquia Jesus de Nazaré',
    location: 'Palmas - TO'
  },
  {
    image: foto4,
    alt: 'Santa Missa',
    description: 'Paróquia Santo Expedito',
    location: 'Palmas - TO'
  },
  {
    image: foto5,
    alt: 'Visita aos enfermos',
    description: 'UPA SUL',
    location: 'Palmas - TO'
  },
  {
    image: foto6,
    alt: 'Partilha da Palavra de Deus',
    description: 'Comunidade São Matias',
    location: 'Palmas - TO'
  }
]
---

<section id="sobre" data-slot="sobre-projeto" class="bg-bg-azul relative overflow-hidden py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Image -->
      <div class="relative flex items-center justify-center">
        <Image
          src={logoColorida}
          alt="Logo Projeto Padres para Palmas"
          class="h-auto w-3/4 max-w-md object-contain sm:w-full"
          loading="lazy"
          widths={[200, 384]}
          sizes="(max-width: 640px) 75vw, 384px"
        />
      </div>

      <!-- Content -->
      <div>
        <span class="text-verde mb-4 inline-block text-sm font-semibold tracking-wider uppercase">
          {sectionLabel}
        </span>
        <h2 class="text-grafite mb-6 text-3xl leading-tight font-light sm:text-4xl">
          {title} <span class="font-semibold">{titleHighlight}</span>
        </h2>
        {paragraphs.map((paragraph) => (
          <p class="text-grafite/80 mb-6 text-lg leading-relaxed">{paragraph}</p>
        ))}
        <a
          href={buttonLink}
          class="bg-azul hover:bg-azul/90 inline-flex items-center gap-2 rounded-full px-6 py-3 font-semibold text-white transition-all duration-300"
        >
          {buttonText}
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto mt-24 max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <span class="text-verde mb-4 inline-block text-sm font-semibold tracking-wider uppercase">
        Galeria
      </span>
      <h3 class="text-grafite text-3xl font-light">
        Registros da <span class="font-semibold">Experiência Vocacional Missionária</span>
      </h3>
    </div>

    <Gallery items={galleryItems} />
  </div>
</section>
