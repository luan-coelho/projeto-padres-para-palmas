---
import { Image } from 'astro:assets'
import { SOCIAL_LINKS, USEFUL_LINKS } from '../consts'
import logoBranca from '../assets/images/logo-branca.png'

const currentYear = new Date().getFullYear()
---

<footer data-slot="footer" class="bg-grafite py-16 text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Logo e Frase -->
      <div class="text-center md:text-left">
        <Image
          src={logoBranca}
          alt="Projeto Padres"
          class="mx-auto mb-4 h-16 w-auto md:mx-0"
          loading="lazy"
          width={200}
        />
        <p class="text-white/80 italic">
          &quot;Farei de ti pescador de homens&quot; (Mt 4,19)
        </p>
      </div>

      <!-- Links Úteis -->
      <div class="text-center">
        <h4 class="mb-4 text-lg font-semibold">Links Úteis</h4>
        <ul class="space-y-2">
          {
            USEFUL_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-amarelo text-white/70 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Redes Sociais -->
      <div class="text-center md:text-right">
        <h4 class="mb-4 text-lg font-semibold">Redes Sociais</h4>
        <div class="flex justify-center space-x-4 md:justify-end">
          {
            SOCIAL_LINKS.instagram && SOCIAL_LINKS.instagram !== '#' && (
              <a
                href={SOCIAL_LINKS.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:bg-azul flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-colors"
                aria-label="Instagram"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-5 w-5"
                >
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
                </svg>
              </a>
            )
          }
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-8 text-center">
      <p class="text-sm text-white/50">
        &copy; {currentYear} Projeto Padres para a Igreja de Palmas. Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>
